# Copy to .env and fill in values

# PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/tena_sabi_db"

# API
PORT=3001
FRONTEND_URL=http://YOUR_HOST

# Next.js
NEXT_PUBLIC_API_URL=http://YOUR_HOST/api

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SECRET=replace-with-a-long-random-secret
ADMIN_COOKIE_SECURE=false
